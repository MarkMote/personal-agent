\frametitle{Safety-Critical Control}\framesubtitle {\small \textbf {Given:} Input-constrained dynamical system, with \textbf {state} $x \in X \subseteq \mathbb {R}^n$ and \textbf {input} $u \in U \subset \mathbb {R}^m$ \eqbox {\dot {x} = F(x, u)} \textbf {Safety} defined by constraints on the state: \eqbox {\varphi _i(x) \geq 0, \quad i = 1, \ldots , M} The set of states satisfying all constraints is the \textbf {constraint set} (also called \textit {allowable set}): \eqbox {\mathcal {C}_A := \{x \in X \mid \varphi _i(x) \geq 0, \;\; i = 1, \ldots , M\}} \textbf {Not all states in the constraint set are safe!} }
